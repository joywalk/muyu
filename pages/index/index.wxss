/* pages/index/index.wxss */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
  position: relative;
  background: linear-gradient(180deg, #111827 0%, #000000 100%);
  color: #fff;
  overflow: hidden;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
  z-index: 10;
  margin-top: -100rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 800;
  display: block;
  margin-bottom: 16rpx;
  background: linear-gradient(90deg, #F59E0B, #FBBF24);
  -webkit-background-clip: text;
  color: transparent;
  text-shadow: 0 4rpx 20rpx rgba(245, 158, 11, 0.2);
}

.subtitle {
  font-size: 28rpx;
  color: #9CA3AF;
  display: block;
  letter-spacing: 2rpx;
}

.count-container {
  text-align: center;
  margin-bottom: 120rpx;
  z-index: 10;
}

.count-number {
  font-size: 110rpx;
  font-weight: 900;
  color: #FBBF24;
  display: block;
  margin-bottom: 10rpx;
  text-shadow: 0 0 40rpx rgba(251, 191, 36, 0.4);
}

.count-label {
  font-size: 32rpx;
  color: #6B7280;
  display: block;
  text-transform: uppercase;
  letter-spacing: 4rpx;
}

.fish-container {
  position: relative;
  width: 500rpx;
  height: 500rpx;
  margin-bottom: 120rpx;
  z-index: 20;
}

.fish-box {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: transparent;
  transition: transform 0.15s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.fish-box:active {
  transform: scale(0.92);
}

.fish-image {
  width: 600rpx;
  height: 600rpx;
  filter: drop-shadow(0 20rpx 40rpx rgba(0,0,0,0.8));
}

/* +1 动画容器 */
.plus-animations {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.plus-animation {
  position: absolute;
  top: 30%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.plus-text {
  font-size: 48rpx;
  font-weight: 800;
  color: #F59E0B;
  text-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.5);
}

.settings-btn {
  position: absolute;
  bottom: 80rpx;
  right: 60rpx;
  background: rgba(31, 41, 55, 0.8);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 60rpx;
  padding: 24rpx 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  gap: 16rpx;
  transition: all 0.3s ease;
  z-index: 30;
}

.settings-btn:active {
  transform: scale(0.95);
  background: rgba(55, 65, 81, 0.9);
}

.settings-icon {
  font-size: 36rpx;
}

.settings-text {
  font-size: 30rpx;
  color: #E5E7EB;
  font-weight: 500;
}
